# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== MongoDB =====
# MONGO_URI=mongodb://127.0.0.1:27017/taka_sathi
# For MongoDB Atlas, use something like:
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.mongodb.net/taka_sathi

# ===== Auth =====
JWT_SECRET=long_unique_string
JWT_EXPIRES_IN=7d
OTP_EXPIRES_IN_MINUTES=5
# Set to "true" to bypass real OTP delivery and auto-accept "123456" (demo/hackathon mode)
OTP_DEMO_MODE=true

# ===== Gemma 4 Inference (self-hosted via Ollama) =====
# Run locally: `ollama pull gemma4:4b` (or whichever tag matches your Gemma 4 build)
#              `ollama serve`
GEMMA_BASE_URL=http://127.0.0.1:11434
GEMMA_MODEL=gemma4:4b
GEMMA_TIMEOUT_MS=30000
# Set to "true" to skip live model calls and use canned mock responses (useful when Ollama isn't running)
GEMMA_MOCK_MODE=true

# ===== CORS =====
CLIENT_ORIGIN=http://localhost:5173

# ===== Rate limiting =====
OTP_RATE_LIMIT_WINDOW_MIN=15
OTP_RATE_LIMIT_MAX=5
